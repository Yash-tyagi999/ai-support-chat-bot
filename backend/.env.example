PORT=5000

# Allowed production origins for CORS (comma-separated if multiple)
FRONTEND_URL=https://frontend.vercel.app
# OpenAI LLM API Configuration
# If omitted, the backend will safely fall back to an offline FAQ keyword-matching mock.
OPENAI_API_KEY=

# Custom LLM settings (Optional: use for custom endpoints like Groq / OpenRouter)
# Example for Groq: 
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.1-8b-instant
OPENAI_BASE_URL=
OPENAI_MODEL=
